# Build-time capability flags (see src/config/capabilities.ts).
# Unset => enabled (full open-web build). Native app-store shell builds opt out
# of the token/marketplace/wallet flows to satisfy store policies:
#
#   VITE_CAP_TOKEN=false VITE_CAP_MARKETPLACE=false VITE_CAP_WALLET=false npm run build
#
VITE_CAP_TOKEN=true
VITE_CAP_MARKETPLACE=true
VITE_CAP_WALLET=true

# Optional: when a flow is disabled, redirect it to this external base URL
# (open in system browser) instead of hiding it outright. Empty => hide.
VITE_CAP_REDIRECT_BASE_URL=

# Edge / session config (see src/config/session.ts). Auth is handled entirely by
# the Kong/OPA edge (trusted identity headers) — the PWA never parses tokens or
# handles passwords. Unset => the same-origin defaults below.
#
# Backend "who am I" endpoint that echoes the edge-asserted identity/tenant:
VITE_SESSION_ENDPOINT=/api/session
# Gateway sign-in entry (redirect target for the OIDC hand-off):
VITE_GATEWAY_SIGNIN_URL=/oauth2/start
# Gateway sign-out entry (empty => hide the sign-out link):
VITE_GATEWAY_SIGNOUT_URL=/oauth2/sign_out
# Query param the gateway reads for the post-sign-in return URL:
VITE_GATEWAY_RETURN_PARAM=rd

# API / realtime endpoints (see src/config/api.ts). Base URLs derive from the
# platform's `{service}.{project}.vforce360.ai` naming and are environment-
# configurable. `dev` defaults to same-origin (`/v1`, same-origin ws://) so a
# local edge proxy just works; `testnet`/`prod` derive real hosts.
#
#   dev     => /v1                                   ws(s)://<page-origin>
#   testnet => https://api.testnet.made.vforce360.ai/v1   wss://ws.testnet.made.vforce360.ai
#   prod    => https://api.made.vforce360.ai/v1           wss://ws.made.vforce360.ai
#
VITE_API_ENV=dev
VITE_API_PROJECT=made
# Explicit overrides (win over the derived hosts; trailing slash trimmed):
VITE_API_BASE_URL=
VITE_WS_BASE_URL=
# Per-environment API capability flags (unset => enabled). Turn a not-yet-
# deployed surface off for a tier without a rebuild:
VITE_API_CAP_COLLECTION=true
VITE_API_CAP_LEADERBOARD=true
VITE_API_CAP_SHOP=true
VITE_API_CAP_CATALOG=true
